# Vite exposes vars prefixed with VITE_ to the browser bundle.
# Copy to reader/.env and fill in your values.

# ── AI Backend ────────────────────────────────────────────────────────────
# Supports Ollama and OpenAI-compatible endpoints (LM Studio, etc).

# Base URL (required):
#   Ollama: http://localhost:11434
#   LM Studio / OpenAI: http://localhost:1234/v1
VITE_AI_BASE_URL=http://localhost:11434

# API format: "ollama" (default) or "openai"
VITE_AI_FORMAT=ollama

# Model to use (optional — defaults to VITE_AI_FAST_MODEL then "llama3.2")
VITE_AI_MAIN_MODEL=
VITE_AI_FAST_MODEL=

# ── Legacy (still supported, VITE_AI_* takes precedence) ──────────────────
# VITE_OLLAMA_BASE_URL=https://your-ollama-tunnel.trycloudflare.com
# VITE_OLLAMA_MAIN_MODEL=lfm2:latest
# VITE_OLLAMA_FAST_MODEL=granite4:3b
