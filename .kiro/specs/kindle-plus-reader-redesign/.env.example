# Environment Variables for LiquidFlow Project

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FAST_MODEL=llama2-7b-chat  # Model for low-latency tasks
OLLAMA_MAIN_MODEL=llama3-8b-chat # Model for richer generation

# Application Configuration
VITE_OLLAMA_BASE_URL=${OLLAMA_BASE_URL}
VITE_OLLAMA_FAST_MODEL=${OLLAMA_FAST_MODEL}
VITE_OLLAMA_MAIN_MODEL=${OLLAMA_MAIN_MODEL}

# System Settings
FONT_BASE_SIZE=16
MAX_CANVAS_WIDTH=680
DEFAULT_TRANSITION_STYLE=particle-drift