# ── LiquidFlow Environment Config ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Ollama instance URL (local or tunnelled)
# Examples:
#   http://localhost:11434          (local Ollama)
#   https://your-tunnel.trycloudflare.com  (Cloudflare tunnel)
OLLAMA_BASE_URL=https://your-ollama-tunnel.trycloudflare.com

# Model to use for heavy tasks (lore cards, rich generation)
OLLAMA_MAIN_MODEL=lfm2:latest

# Model to use for fast/bulk tasks (scene annotation, ASCII prompts)
OLLAMA_FAST_MODEL=granite4:3b
